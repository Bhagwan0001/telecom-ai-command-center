# TAICC Server Environment Variables

NODE_ENV=development
PORT=4000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/taicc"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-this-to-a-secure-secret-in-production-min-32"
JWT_REFRESH_SECRET="change-this-refresh-secret-in-production-min-32"

# CORS
CORS_ORIGIN="http://localhost:3000"
